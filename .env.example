# Backend Configuration
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/telegram-shop?retryWrites=true&w=majority

# Telegram Bot
TELEGRAM_BOT_TOKEN=<your_telegram_bot_token_from_botfather>
TELEGRAM_ADMIN_CHANNEL_ID=<your_admin_channel_id>
TELEGRAM_WEBAPP_URL=<your_webapp_url>

# Frontend
VITE_API_BASE_URL=http://localhost:5000/api
VITE_TELEGRAM_BOT_TOKEN=<your_telegram_bot_token>

# Payment Gateway (optional)
PAYMENT_PROVIDER_KEY=<payment_provider_api_key>
PAYMENT_PROVIDER_SECRET=<payment_provider_secret>

# JWT Secret (for authentication)
JWT_SECRET=<your_jwt_secret_key>
